---
import { navLinks, siteConfig } from "../data/site";

const normalizePath = (path: string) => (path === "/" ? "/" : path.replace(/\/+$/, ""));
const currentPath = normalizePath(Astro.url.pathname);
---

<header class="site-header">
  <div class="wrap nav-shell">
    <a class="brand" href="/">
      <span class="brand-mark">TC</span>
      <span>
        <strong>{siteConfig.name}</strong>
        <small>Reparacion de techos B2B</small>
      </span>
    </a>

    <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="primary-nav">
      <span class="menu-toggle-icon" aria-hidden="true"></span>
      <span>Menu</span>
    </button>

    <nav id="primary-nav" class="site-nav" data-open="false" aria-label="Principal">
      <ul class="nav-list">
        {
          navLinks.map((link) => (
            <li>
              <a
                class={currentPath === normalizePath(link.href) || currentPath.startsWith(`${normalizePath(link.href)}/`) ? "active" : ""}
                href={link.href}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
      <a class="btn btn-primary nav-cta-mobile" href={siteConfig.whatsapp} target="_blank" rel="noopener noreferrer">
        Cotizar ahora
      </a>
    </nav>
    <a class="btn btn-primary nav-cta-desktop" href={siteConfig.whatsapp} target="_blank" rel="noopener noreferrer">
      Cotizar ahora
    </a>
  </div>
</header>

<script is:inline>
  (() => {
    const header = document.querySelector(".site-header");
    if (!header) return;

    const toggle = header.querySelector(".menu-toggle");
    const nav = header.querySelector("#primary-nav");
    if (!toggle || !nav) return;

    const setOpen = (open) => {
      nav.dataset.open = open ? "true" : "false";
      toggle.setAttribute("aria-expanded", open ? "true" : "false");
    };

    toggle.addEventListener("click", () => {
      const isOpen = nav.dataset.open === "true";
      setOpen(!isOpen);
    });

    nav.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => setOpen(false));
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth > 900) {
        setOpen(false);
      }
    });
  })();
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    backdrop-filter: blur(10px);
    background: rgba(241, 245, 248, 0.9);
    border-bottom: 1px solid var(--line);
  }

  .nav-shell {
    min-height: 74px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.9rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    color: var(--ink);
  }

  .brand strong {
    display: block;
    line-height: 1;
    letter-spacing: 0.01em;
  }

  .brand small {
    display: block;
    color: var(--ink-soft);
    font-size: 0.76rem;
  }

  .brand-mark {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-family: "Barlow Condensed", sans-serif;
    font-size: 1.12rem;
    background: linear-gradient(135deg, var(--brand-2), var(--brand));
    box-shadow: 0 10px 24px rgba(14, 35, 54, 0.25);
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 0.25rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .nav-list a {
    text-decoration: none;
    color: var(--ink-soft);
    font-weight: 700;
    border-radius: 8px;
    padding: 0.45rem 0.62rem;
    display: inline-flex;
  }

  .nav-list a:hover,
  .nav-list a.active {
    color: var(--brand-2);
    background: #e8f0f6;
  }

  .nav-cta-desktop {
    font-size: 0.9rem;
    padding: 0.64rem 0.84rem;
    white-space: nowrap;
  }

  .nav-cta-mobile {
    display: none;
  }

  .menu-toggle {
    display: none;
    align-items: center;
    gap: 0.45rem;
    border: 1px solid var(--line);
    background: #fff;
    color: var(--brand-2);
    border-radius: 10px;
    padding: 0.45rem 0.62rem;
    font-weight: 700;
    font: inherit;
    cursor: pointer;
  }

  .menu-toggle-icon {
    width: 18px;
    height: 2px;
    background: var(--brand-2);
    border-radius: 999px;
    position: relative;
  }

  .menu-toggle-icon::before,
  .menu-toggle-icon::after {
    content: "";
    position: absolute;
    left: 0;
    width: 18px;
    height: 2px;
    border-radius: 999px;
    background: var(--brand-2);
  }

  .menu-toggle-icon::before {
    top: -5px;
  }

  .menu-toggle-icon::after {
    top: 5px;
  }

  @media (max-width: 900px) {
    .nav-shell {
      position: relative;
      padding: 0.6rem 0;
    }

    .brand {
      flex: 1;
      min-width: 0;
    }

    .brand small {
      display: none;
    }

    .menu-toggle {
      display: inline-flex;
    }

    .nav-cta-desktop {
      display: none;
    }

    .site-nav {
      display: none;
      position: absolute;
      top: calc(100% + 6px);
      left: 0;
      right: 0;
      z-index: 30;
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 14px;
      box-shadow: 0 18px 36px rgba(17, 32, 49, 0.14);
      padding: 0.7rem;
    }

    .site-nav[data-open="true"] {
      display: block;
    }

    .nav-list {
      flex-direction: column;
      align-items: stretch;
      gap: 0.25rem;
    }

    .nav-list a {
      width: 100%;
      padding: 0.58rem 0.65rem;
    }

    .nav-cta-mobile {
      display: inline-flex;
      width: 100%;
      margin-top: 0.55rem;
    }
  }
</style>
