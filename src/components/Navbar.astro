---
import { navLinks, planSubmenuLinks, sectorSubmenuLinks, serviceSubmenuLinks, siteConfig } from "../data/site";

const normalizePath = (path: string) => (path === "/" ? "/" : path.replace(/\/+$/, ""));
const currentPath = normalizePath(Astro.url.pathname);
---

<header class="site-header">
  <div class="wrap nav-shell">
    <a class="brand" href="/">
      <span class="brand-mark">TC</span>
      <span>
        <strong>{siteConfig.name}</strong>
        <small>Reparacion de techos B2B</small>
      </span>
    </a>

    <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="primary-nav" aria-label="Abrir menu principal">
      <span class="menu-toggle-icon" aria-hidden="true"></span>
      <span class="sr-only">Menu</span>
    </button>

    <nav id="primary-nav" class="site-nav" data-open="false" aria-label="Principal">
      <ul class="nav-list">
        {
          navLinks.map((link) => {
            const normalizedHref = normalizePath(link.href);
            const linkIsActive = currentPath === normalizedHref || currentPath.startsWith(`${normalizedHref}/`);
            const submenuConfig =
              normalizedHref === "/servicios"
                ? { items: serviceSubmenuLinks, ariaLabel: "Subpaginas de servicios" }
                : normalizedHref === "/planes-mantencion"
                  ? { items: planSubmenuLinks, ariaLabel: "Tipos de plan de mantencion" }
                : normalizedHref === "/sectores"
                  ? { items: sectorSubmenuLinks, ariaLabel: "Subsectores atendidos" }
                  : null;
            const hasSubmenu = Boolean(submenuConfig);

            return (
              <li class={`nav-item${hasSubmenu ? " has-submenu" : ""}`}>
                <a class={linkIsActive ? "active" : ""} href={link.href}>
                  {link.label}
                  {hasSubmenu && <span class="nav-caret" aria-hidden="true">v</span>}
                </a>
                {
                  submenuConfig && (
                    <ul
                      class={`submenu-list${submenuConfig.items.length > 4 ? " submenu-two-col" : ""}`}
                      aria-label={submenuConfig.ariaLabel}
                    >
                      {
                        submenuConfig.items.map((item) => {
                          const targetPath = normalizePath(item.href.split("#")[0]);
                          const itemIsHashLink = item.href.includes("#");
                          const itemIsActive = !itemIsHashLink && currentPath === targetPath;
                          return (
                            <li>
                              <a class={itemIsActive ? "active" : ""} href={item.href}>{item.label}</a>
                            </li>
                          );
                        })
                      }
                    </ul>
                  )
                }
              </li>
            );
          })
        }
      </ul>
      <a class="btn btn-primary nav-cta-mobile" href={siteConfig.whatsapp} target="_blank" rel="noopener noreferrer">
        Cotizar ahora
      </a>
    </nav>
    <div class="nav-actions-desktop">
      <a class="btn btn-secondary nav-price-desktop" href="/precios/">
        Precios
      </a>
      <a class="btn btn-primary nav-cta-desktop" href={siteConfig.whatsapp} target="_blank" rel="noopener noreferrer">
        Cotizar ahora
      </a>
    </div>
  </div>
  <button class="nav-overlay" type="button" aria-label="Cerrar menu" tabindex="-1"></button>
</header>

<script is:inline>
  (() => {
    const header = document.querySelector(".site-header");
    if (!header) return;

    const toggle = header.querySelector(".menu-toggle");
    const nav = header.querySelector("#primary-nav");
    const overlay = header.querySelector(".nav-overlay");
    if (!toggle || !nav || !overlay) return;

    const setOpen = (open) => {
      nav.dataset.open = open ? "true" : "false";
      toggle.setAttribute("aria-expanded", open ? "true" : "false");
      header.dataset.open = open ? "true" : "false";
      document.documentElement.classList.toggle("nav-locked", open);
      document.body.classList.toggle("nav-locked", open);
    };

    toggle.addEventListener("click", () => {
      const isOpen = nav.dataset.open === "true";
      setOpen(!isOpen);
    });

    nav.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => setOpen(false));
    });

    overlay.addEventListener("click", () => setOpen(false));

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        setOpen(false);
      }
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth > 900) {
        setOpen(false);
      }
    });
  })();
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    backdrop-filter: blur(10px);
    background: rgba(243, 245, 247, 0.92);
    border-bottom: 1px solid var(--line);
  }

  .nav-shell {
    position: relative;
    z-index: 41;
    min-height: 74px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.9rem;
    transition: border-radius 160ms ease, box-shadow 160ms ease, background 160ms ease;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    color: var(--ink);
  }

  .brand strong {
    display: block;
    line-height: 1;
    letter-spacing: 0.01em;
  }

  .brand small {
    display: block;
    color: var(--ink-soft);
    font-size: 0.76rem;
  }

  .brand-mark {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-family: "Barlow Condensed", sans-serif;
    font-size: 1.12rem;
    background: linear-gradient(135deg, var(--brand-2), var(--brand));
    box-shadow: 0 10px 24px rgba(17, 19, 23, 0.28);
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 0.25rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .nav-item {
    position: relative;
  }

  .nav-list > li > a {
    text-decoration: none;
    color: var(--ink-soft);
    font-weight: 700;
    border-radius: 8px;
    padding: 0.45rem 0.62rem;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .nav-list > li > a:hover,
  .nav-list > li > a.active {
    color: var(--brand-2);
    background: #e6eaef;
  }

  .nav-caret {
    font-size: 0.72rem;
    line-height: 1;
    color: #6b7280;
  }

  .submenu-list {
    position: absolute;
    top: 100%;
    left: 0;
    list-style: none;
    margin: 0;
    padding: 0.45rem;
    min-width: 300px;
    max-width: min(420px, calc(100vw - 2rem));
    max-height: none;
    overflow: visible;
    border-radius: 12px;
    border: 1px solid var(--line);
    background: #fff;
    box-shadow: 0 18px 36px rgba(17, 19, 23, 0.18);
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.22rem;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: none;
    transition: opacity 140ms ease, visibility 140ms ease;
    z-index: 46;
  }

  .submenu-list.submenu-two-col {
    min-width: 520px;
    max-width: min(620px, calc(100vw - 2rem));
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .submenu-list a {
    display: block;
    text-decoration: none;
    color: var(--ink-soft);
    font-weight: 600;
    line-height: 1.2;
    border-radius: 8px;
    padding: 0.5rem 0.56rem;
  }

  .submenu-list a:hover,
  .submenu-list a.active {
    color: var(--brand-2);
    background: #f1f4f7;
  }

  .nav-item.has-submenu:hover > .submenu-list,
  .nav-item.has-submenu:focus-within > .submenu-list {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: none;
  }

  .nav-cta-desktop {
    font-size: 0.9rem;
    padding: 0.64rem 0.84rem;
    white-space: nowrap;
  }

  .nav-actions-desktop {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .nav-price-desktop {
    font-size: 0.9rem;
    padding: 0.64rem 0.84rem;
    white-space: nowrap;
  }

  .nav-cta-mobile {
    display: none;
  }

  .menu-toggle {
    display: none;
    align-items: center;
    border: 1px solid var(--line);
    background: #fff;
    color: var(--brand-2);
    border-radius: 12px;
    padding: 0.56rem;
    font: inherit;
    cursor: pointer;
  }

  .menu-toggle-icon {
    width: 18px;
    height: 2px;
    background: var(--brand-2);
    border-radius: 999px;
    position: relative;
  }

  .menu-toggle-icon::before,
  .menu-toggle-icon::after {
    content: "";
    position: absolute;
    left: 0;
    width: 18px;
    height: 2px;
    border-radius: 999px;
    background: var(--brand-2);
  }

  .menu-toggle-icon::before {
    top: -5px;
  }

  .menu-toggle-icon::after {
    top: 5px;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .nav-overlay {
    display: none;
    border: 0;
    margin: 0;
    padding: 0;
    background: rgba(15, 18, 23, 0.44);
    backdrop-filter: blur(10px) saturate(120%);
    -webkit-backdrop-filter: blur(10px) saturate(120%);
    position: fixed;
    inset: 0;
    z-index: 39;
    opacity: 0;
    pointer-events: none;
    transition: opacity 180ms ease;
  }

  :global(html.nav-locked),
  :global(body.nav-locked) {
    overflow: hidden;
    touch-action: none;
    overscroll-behavior: none;
  }

  :global(body main),
  :global(body footer) {
    transition: filter 180ms ease;
  }

  :global(body.nav-locked main),
  :global(body.nav-locked footer) {
    filter: blur(3px);
  }

  @media (max-width: 900px) {
    .site-header .nav-shell {
      width: 100%;
      max-width: none;
      margin: 0;
    }

    .nav-shell {
      position: relative;
      padding: 0.6rem 0.9rem;
      background: #f3f5f7;
      border: 1px solid transparent;
      border-left: 0;
      border-right: 0;
      border-radius: 0;
    }

    .brand {
      flex: 1;
      min-width: 0;
    }

    .brand small {
      display: none;
    }

    .menu-toggle {
      display: inline-flex;
    }

    .nav-cta-desktop {
      display: none;
    }

    .nav-actions-desktop {
      display: none;
    }

    .site-nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      z-index: 42;
      background: #fff;
      border: 1px solid var(--line);
      border-top: 0;
      border-left: 0;
      border-right: 0;
      border-radius: 0;
      box-shadow: 0 18px 36px rgba(17, 19, 23, 0.14);
      padding: 0.7rem;
    }

    .site-nav[data-open="true"] {
      display: block;
    }

    .nav-list {
      flex-direction: column;
      align-items: stretch;
      gap: 0.25rem;
    }

    .nav-list > li > a {
      width: 100%;
      padding: 0.58rem 0.65rem;
    }

    .submenu-list {
      position: static;
      min-width: 0;
      max-width: none;
      max-height: none;
      grid-template-columns: 1fr;
      margin-top: 0.2rem;
      padding: 0.35rem;
      border-radius: 10px;
      border: 1px solid #d9dfe6;
      box-shadow: none;
      background: #f3f5f7;
      display: none;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transform: none;
      transition: none;
    }

    .submenu-list a {
      padding: 0.46rem 0.55rem;
      font-size: 0.93rem;
    }

    .nav-item.has-submenu:hover > .submenu-list,
    .nav-item.has-submenu:focus-within > .submenu-list {
      display: grid;
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }

    .nav-cta-mobile {
      display: inline-flex;
      width: 100%;
      margin-top: 0.55rem;
    }

    .site-header[data-open="true"] .nav-overlay {
      display: block;
      opacity: 1;
      pointer-events: auto;
    }

    .site-header[data-open="true"] .menu-toggle-icon {
      background: transparent;
    }

    .site-header[data-open="true"] .nav-shell {
      background: #fff;
      border-color: var(--line);
      border-left: 0;
      border-right: 0;
      border-radius: 0;
      box-shadow: 0 12px 30px rgba(17, 19, 23, 0.22);
    }

    .site-header[data-open="true"] .menu-toggle-icon::before {
      top: 0;
      transform: rotate(45deg);
    }

    .site-header[data-open="true"] .menu-toggle-icon::after {
      top: 0;
      transform: rotate(-45deg);
    }
  }
</style>
