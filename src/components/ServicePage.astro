---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "./Icon.astro";

interface Props {
  title: string;
  description: string;
  h1: string;
  intro: string;
  bullets: string[];
  process: string[];
}

const { title, description, h1, intro, bullets, process } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <section class="hero-shell">
    <div class="wrap hero-box">
      <span class="kicker">Servicio especializado</span>
      <h1>{h1}</h1>
      <p>{intro}</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/contacto/">Solicitar evaluacion tecnica</a>
        <a class="btn btn-secondary" href="/servicios/">Volver a servicios</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap grid-2">
      <article class="panel card">
        <h2 class="title-with-icon">
          <span class="icon-chip"><Icon name="checklist" size={18} /></span>
          Que incluye este servicio
        </h2>
        <ul class="list-icon">
          {
            bullets.map((item) => (
              <li>
                <Icon name="shield" class="bullet-icon" size={16} />
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </article>
      <article class="panel card">
        <h2 class="title-with-icon">
          <span class="icon-chip"><Icon name="tool" size={18} /></span>
          Metodologia de ejecucion
        </h2>
        <ul class="list-icon">
          {
            process.map((step) => (
              <li>
                <Icon name="clock" class="bullet-icon" size={16} />
                <span>{step}</span>
              </li>
            ))
          }
        </ul>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .card {
    padding: 1rem;
  }
</style>
