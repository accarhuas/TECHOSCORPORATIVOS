---
import { navLinks, serviceLinks, siteConfig } from "../data/site";
---

<footer class="site-footer">
  <div class="wrap footer-grid">
    <section>
      <h2>{siteConfig.name}</h2>
      <p>
        Reparacion de techos, cambio de techos e impermeabilizacion para empresas,
        bodegas, colegios y sucursales en Chile.
      </p>
      <p class="muted">{siteConfig.legalName}</p>
    </section>
    <section>
      <h3>Navegacion</h3>
      <ul>
        {navLinks.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
      </ul>
    </section>
    <section>
      <h3>Servicios</h3>
      <ul>
        {serviceLinks.map((item) => <li><a href={item.href}>{item.title}</a></li>)}
      </ul>
    </section>
    <section>
      <h3>Contacto</h3>
      <ul>
        <li><a href={`tel:${siteConfig.phoneRaw}`}>{siteConfig.phoneDisplay}</a></li>
        <li><a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></li>
        <li>{siteConfig.address}</li>
        <li>
          <a href={siteConfig.whatsapp} target="_blank" rel="noopener noreferrer">WhatsApp</a>
        </li>
      </ul>
    </section>
  </div>
  <div class="wrap footer-bar">
    <span>{new Date().getFullYear()} {siteConfig.name}. Todos los derechos reservados.</span>
    <span>Cobertura nacional segun requerimiento operativo.</span>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: clamp(2rem, 5vw, 4rem);
    color: #d7e5ee;
    background:
      linear-gradient(170deg, rgba(255, 138, 0, 0.08), transparent 40%),
      linear-gradient(180deg, #091726, #0f2940);
    border-top: 1px solid rgba(255, 255, 255, 0.09);
  }

  .footer-grid {
    padding: 2rem 0 1.5rem;
    display: grid;
    gap: 1rem;
    grid-template-columns: 1.3fr 1fr 1fr 1fr;
  }

  .site-footer h2,
  .site-footer h3 {
    color: #fff;
    margin-bottom: 0.6rem;
  }

  .site-footer p {
    color: #d7e5ee;
  }

  .site-footer .muted {
    color: #9ab1c2;
    margin-top: 0.8rem;
  }

  .site-footer ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-footer li {
    margin-bottom: 0.42rem;
  }

  .site-footer a {
    color: #d7e5ee;
    text-decoration: none;
  }

  .site-footer a:hover {
    color: #fff;
    text-decoration: underline;
  }

  .footer-bar {
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    padding: 0.75rem 0 1rem;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.35rem;
    color: #a5bccb;
    font-size: 0.88rem;
  }

  @media (max-width: 980px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
