---
import { footerLinks, serviceLinks, siteConfig } from "../data/site";
import Icon from "./Icon.astro";
---

<footer class="site-footer">
  <div class="wrap footer-grid">
    <section>
      <h2 class="title-with-icon">
        <span class="icon-chip icon-chip-accent"><Icon name="building" size={18} /></span>
        {siteConfig.name}
      </h2>
      <p>
        Reparacion de techos, cambio de techos e impermeabilizacion para empresas,
        bodegas, colegios y sucursales en Chile.
      </p>
      <p class="muted">{siteConfig.legalName}</p>
    </section>
    <section>
      <h3 class="title-with-icon">
        <span class="icon-chip"><Icon name="checklist" size={16} /></span>
        Navegacion
      </h3>
      <ul>
        {footerLinks.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
      </ul>
    </section>
    <section>
      <h3 class="title-with-icon">
        <span class="icon-chip"><Icon name="tool" size={16} /></span>
        Servicios
      </h3>
      <ul>
        {serviceLinks.map((item) => <li><a href={item.href}>{item.title}</a></li>)}
      </ul>
    </section>
    <section>
      <h3 class="title-with-icon">
        <span class="icon-chip"><Icon name="phone" size={16} /></span>
        Contacto
      </h3>
      <ul class="list-icon">
        <li>
          <Icon name="phone" class="bullet-icon" size={15} />
          <a href={`tel:${siteConfig.phoneRaw}`}>{siteConfig.phoneDisplay}</a>
        </li>
        <li>
          <Icon name="mail" class="bullet-icon" size={15} />
          <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
        </li>
        <li>
          <Icon name="map-pin" class="bullet-icon" size={15} />
          <span>{siteConfig.address}</span>
        </li>
        <li>
          <Icon name="chat" class="bullet-icon" size={15} />
          <a href={siteConfig.whatsapp} target="_blank" rel="noopener noreferrer">WhatsApp</a>
        </li>
      </ul>
    </section>
  </div>
  <div class="wrap footer-bar">
    <span>{new Date().getFullYear()} {siteConfig.name}. Todos los derechos reservados.</span>
    <span>Cobertura nacional segun requerimiento operativo.</span>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    overflow: hidden;
    margin-top: clamp(2rem, 5vw, 4rem);
    color: #d5d9e0;
    background: linear-gradient(180deg, #242b34, #141920);
    border-top: 1px solid rgba(255, 210, 0, 0.3);
  }

  .site-footer::before {
    content: "";
    position: absolute;
    right: -140px;
    top: -130px;
    width: 360px;
    height: 240px;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(255, 210, 0, 0.14), rgba(255, 210, 0, 0) 70%);
    pointer-events: none;
    z-index: 0;
  }

  .footer-grid,
  .footer-bar {
    position: relative;
    z-index: 1;
  }

  .footer-grid {
    padding: 2rem 0 1.5rem;
    display: grid;
    gap: 1rem;
    grid-template-columns: 1.3fr 1fr 1fr 1fr;
  }

  .site-footer h2,
  .site-footer h3 {
    color: #fff;
    margin-bottom: 0.6rem;
  }

  .site-footer .title-with-icon {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .site-footer .icon-chip {
    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.2);
    color: #fff;
  }

  .site-footer .icon-chip.icon-chip-accent {
    color: #1e242c;
    background: #ffd200;
    border-color: rgba(255, 210, 0, 0.7);
  }

  .site-footer p {
    color: #d5d9e0;
  }

  .site-footer .muted {
    color: #a5aeb9;
    margin-top: 0.8rem;
  }

  .site-footer ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-footer li {
    margin-bottom: 0.42rem;
  }

  .site-footer a {
    color: #d5d9e0;
    text-decoration: none;
  }

  .site-footer a:hover {
    color: #ffd200;
    text-decoration: underline;
  }

  .site-footer .list-icon {
    gap: 0.45rem;
  }

  .site-footer .list-icon li {
    color: #d5d9e0;
    grid-template-columns: 20px 1fr;
  }

  .site-footer .bullet-icon {
    color: #ffd200;
  }

  .footer-bar {
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    padding: 0.75rem 0 1rem;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.35rem;
    color: #aab2bc;
    font-size: 0.88rem;
  }

  @media (max-width: 980px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
