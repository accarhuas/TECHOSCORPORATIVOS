---
interface Props {
  name: string;
  size?: number;
  class?: string;
}

const { name, size = 20, class: className = "" } = Astro.props;
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.9"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
>
  {
    name === "shield" && (
      <>
        <path d="M12 3l7 3.2v6.1c0 5-3.4 7.5-7 9.2-3.6-1.7-7-4.2-7-9.2V6.2L12 3z"></path>
        <path d="M9.2 12.2l1.8 1.9 3.8-4"></path>
      </>
    )
  }
  {
    name === "clock" && (
      <>
        <circle cx="12" cy="12" r="8.5"></circle>
        <path d="M12 7.6v4.8l3 1.8"></path>
      </>
    )
  }
  {
    name === "building" && (
      <>
        <path d="M4 20V6.8L12 4l8 2.8V20"></path>
        <path d="M9 20v-4h6v4"></path>
        <path d="M8 9h0.01M12 9h0.01M16 9h0.01M8 12h0.01M12 12h0.01M16 12h0.01"></path>
      </>
    )
  }
  {
    name === "map-pin" && (
      <>
        <path d="M12 21s6-5.4 6-10a6 6 0 1 0-12 0c0 4.6 6 10 6 10z"></path>
        <circle cx="12" cy="11" r="2.2"></circle>
      </>
    )
  }
  {
    name === "tool" && (
      <>
        <path d="M14.7 5.2a4.3 4.3 0 0 0-5.4 5.4L4.2 15.7a1.7 1.7 0 0 0 2.4 2.4l5.1-5.1a4.3 4.3 0 0 0 5.4-5.4l-2.4 2.4-2.4-2.4 2.4-2.4z"></path>
      </>
    )
  }
  {
    name === "checklist" && (
      <>
        <rect x="5" y="4" width="14" height="16" rx="2"></rect>
        <path d="M9 9h6M9 13h6M9 17h4"></path>
        <path d="M7.1 8.9l.7.7 1.2-1.3M7.1 12.9l.7.7 1.2-1.3"></path>
      </>
    )
  }
  {
    name === "chart" && (
      <>
        <path d="M4 19h16"></path>
        <rect x="6" y="11" width="2.8" height="6" rx="0.5"></rect>
        <rect x="10.6" y="8" width="2.8" height="9" rx="0.5"></rect>
        <rect x="15.2" y="6" width="2.8" height="11" rx="0.5"></rect>
      </>
    )
  }
  {
    name === "wrench" && (
      <>
        <path d="M21 7.5a4.5 4.5 0 0 1-6.2 4.2l-7.2 7.2a2 2 0 1 1-2.8-2.8l7.2-7.2A4.5 4.5 0 0 1 16.5 3l-2.2 2.2 2.5 2.5L19 5.5A4.5 4.5 0 0 1 21 7.5z"></path>
      </>
    )
  }
  {
    name === "phone" && (
      <>
        <path d="M6 4h3l1.2 3.1-1.6 1.6a15 15 0 0 0 6.6 6.6l1.6-1.6L20 15v3a2 2 0 0 1-2.2 2A16.8 16.8 0 0 1 4 6.2 2 2 0 0 1 6 4z"></path>
      </>
    )
  }
  {
    name === "mail" && (
      <>
        <rect x="3.5" y="5.5" width="17" height="13" rx="2"></rect>
        <path d="M4.5 7l7.5 5.7L19.5 7"></path>
      </>
    )
  }
  {
    name === "chat" && (
      <>
        <path d="M5 5.5h14a2 2 0 0 1 2 2v7a2 2 0 0 1-2 2H11l-4.5 3v-3H5a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2z"></path>
      </>
    )
  }
  {
    ![
      "shield",
      "clock",
      "building",
      "map-pin",
      "tool",
      "checklist",
      "chart",
      "wrench",
      "phone",
      "mail",
      "chat"
    ].includes(name) && (
      <>
        <circle cx="12" cy="12" r="8.5"></circle>
        <path d="M8.4 12h7.2M12 8.4v7.2"></path>
      </>
    )
  }
</svg>
