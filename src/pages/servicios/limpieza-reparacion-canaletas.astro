---
import ServicePage from "../../components/ServicePage.astro";

const title = "Limpieza y reparacion de canaletas | Techos Corporativos";
const description =
  "Servicio de limpieza y reparacion de canaletas para empresas en Chile. Prevencion de rebalses, filtraciones y dano por escurrimiento.";
---

<ServicePage
  title={title}
  description={description}
  h1="Limpieza y reparacion de canaletas para control de escurrimiento"
  intro="Mantenemos canaletas y bajadas en condiciones operativas para reducir rebalses, filtraciones y danos en fachada o cubierta."
  bullets={[
    "Limpieza de residuos y despeje de bajadas",
    "Revision de fijaciones, pendientes y uniones",
    "Sellado de fugas en canaletas metalicas",
    "Reparacion o recambio de tramos deteriorados",
    "Informe tecnico con frecuencia recomendada"
  ]}
  process={[
    "Inspeccion visual y prueba de escurrimiento",
    "Limpieza y retiro controlado de residuos",
    "Reparacion de puntos criticos detectados",
    "Cierre tecnico con recomendaciones preventivas"
  ]}
/>
