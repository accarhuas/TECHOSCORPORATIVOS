---
import ServicePage from "../../components/ServicePage.astro";

const title = "Reparacion de cubiertas de naves industriales | Techos Corporativos";
const description =
  "Reparacion de cubiertas en naves industriales y centros logisticos. Soluciones para filtraciones, fijaciones y sellado tecnico en Chile.";
---

<ServicePage
  title={title}
  description={description}
  h1="Reparacion de cubiertas de naves industriales"
  intro="Atendemos naves industriales de gran metraje con metodologia por panos para proteger operacion, inventario y continuidad productiva."
  bullets={[
    "Mapeo de filtraciones por pano y nivel de criticidad",
    "Reparacion de fijaciones, uniones y puntos de dilatacion",
    "Sellado en cumbreras, lucarnas y encuentros con muros",
    "Correccion de escurrimiento y drenaje en sectores criticos",
    "Reporte tecnico para mantenimiento centralizado"
  ]}
  process={[
    "Inspeccion inicial y priorizacion por riesgo operativo",
    "Plan de trabajo por etapas para no detener produccion",
    "Ejecucion tecnica con control de calidad en cada pano",
    "Entrega de informe de cierre y plan de seguimiento"
  ]}
/>
