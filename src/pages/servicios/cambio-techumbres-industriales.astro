---
import ServicePage from "../../components/ServicePage.astro";

const title = "Cambio de techos industriales | Techos Corporativos";
const description =
  "Cambio de techos industriales en Chile. Reemplazo parcial o total de techumbres para empresas, bodegas y centros logisticos.";
---

<ServicePage
  title={title}
  description={description}
  h1="Cambio de techos industriales con plan de continuidad"
  intro="Reemplazamos cubiertas deterioradas sin comprometer operacion critica, con planificacion por etapas y control tecnico."
  bullets={[
    "Levantamiento de estado estructural y de cubierta",
    "Propuesta de cambio parcial o total por sectores",
    "Retiro controlado de cubierta existente",
    "Instalacion de nueva techumbre y elementos de estanqueidad",
    "Plan de mantencion para proteger inversion"
  ]}
  process={[
    "Diagnostico y priorizacion por criticidad de uso",
    "Definicion de ventanas de trabajo con cliente",
    "Ejecucion secuencial para minimizar riesgo operacional",
    "Recepcion tecnica y entrega de informe final"
  ]}
/>
