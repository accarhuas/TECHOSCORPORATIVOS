---
import ServicePage from "../../components/ServicePage.astro";

const title = "Mantencion de techumbres para empresas | Techos Corporativos";
const description =
  "Plan de mantencion programada de techumbres para empresas. Frecuencia mensual, trimestral, semestral o anual con reportes tecnicos.";
---

<ServicePage
  title={title}
  description={description}
  h1="Mantencion programada de techumbres para empresas"
  intro="Disenamos planes de mantencion preventiva y correctiva para reducir urgencias y prolongar la vida util de techos industriales."
  bullets={[
    "Inspecciones calendarizadas por temporada",
    "Deteccion temprana de filtraciones y goteras",
    "Ajuste de fijaciones, sellos y puntos de union",
    "Limpieza de canaletas y control de bajadas",
    "Reporte tecnico y priorizacion de mejoras"
  ]}
  process={[
    "Definicion de frecuencia segun criticidad",
    "Plan de visitas por sede o red de sucursales",
    "Ejecucion de mantencion preventiva programada",
    "Seguimiento con indicadores y acciones sugeridas"
  ]}
/>
