---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
import { serviceLinks } from "../../data/site";

const title = "Servicios de reparacion de techos | Techos Corporativos";
const description =
  "Servicios B2B de reparacion de techos: filtraciones, goteras, impermeabilizacion, cambio de techos y mantencion programada en Chile.";

const additionalServices = [
  {
    href: "/servicios/cambio-cubiertas-techos/",
    title: "Cambio de cubiertas y techos",
    summary: "Reemplazo parcial o total de cubiertas empresariales segun estado y criticidad."
  },
  {
    href: "/servicios/reparacion-por-tipo-de-cubierta/",
    title: "Reparacion por tipo de cubierta",
    summary: "Soluciones para cubierta metalica, policarbonato, teja asfaltica y sistemas mixtos."
  },
  {
    href: "/servicios/reparacion-cubiertas-naves-industriales/",
    title: "Reparacion de cubiertas de naves industriales",
    summary: "Intervencion por panos para instalaciones de gran metraje y operacion continua."
  },
  {
    href: "/servicios/cotizacion-reparacion-techos/",
    title: "Cotizacion de reparacion de techos",
    summary: "Propuesta tecnica y economica con alcance, plazos y ruta de intervencion."
  },
  {
    href: "/servicios/limpieza-reparacion-canaletas/",
    title: "Limpieza y reparacion de canaletas",
    summary: "Control de escurrimiento, limpieza preventiva y reparacion de bajadas."
  },
  {
    href: "/servicios/mantencion-techumbres-empresas/",
    title: "Mantencion programada de techumbres",
    summary: "Planes mensuales, trimestrales, semestrales o anuales segun criticidad."
  },
  {
    href: "/servicios/inspeccion-tecnica-techos/",
    title: "Inspeccion tecnica de techos",
    summary: "Diagnostico tecnico con informe, riesgos y ruta de intervencion priorizada."
  },
  {
    href: "/servicios/sellado-juntas-cumbreras/",
    title: "Sellado de juntas y cumbreras",
    summary: "Refuerzo de estanqueidad en uniones criticas de techumbres metalicas."
  }
];
---

<BaseLayout title={title} description={description}>
  <section class="hero-shell">
    <div class="wrap hero-box">
      <span class="kicker">Portafolio tecnico</span>
      <h1>Servicios de reparacion y mantencion de techumbres</h1>
      <p>
        Atendemos infraestructura empresarial con enfoque preventivo y correctivo. Cada servicio
        se ejecuta con diagnostico, plan tecnico y reporte de cierre.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/contacto/">Solicitar visita tecnica</a>
      </div>
    </div>
  </section>

  <section class="section">
      <div class="wrap grid-2 cards">
      {
        serviceLinks.map((item, index) => (
          <article class="panel card">
            <span class="icon-chip icon-chip-accent"><Icon name={["tool", "shield", "checklist", "wrench", "chart", "clock"][index % 6]} size={18} /></span>
            <h2>{item.title}</h2>
            <p>{item.summary}</p>
            <a href={item.href}>Ver subpagina</a>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <h2>Servicios complementarios y especializados</h2>
      <div class="grid-2 cards">
        {
          additionalServices.map((item, index) => (
            <article class="panel card">
              <span class="icon-chip"><Icon name={["building", "checklist", "wrench", "chat", "tool", "clock", "chart", "shield"][index % 8]} size={18} /></span>
              <h3>{item.title}</h3>
              <p>{item.summary}</p>
              <a href={item.href}>Ver subpagina</a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap panel process">
      <h2 class="title-with-icon">
        <span class="icon-chip"><Icon name="checklist" size={18} /></span>
        Como trabajamos
      </h2>
      <ul class="list-icon">
        <li><Icon name="map-pin" class="bullet-icon" size={16} /><span>Inspeccion tecnica y levantamiento de riesgo.</span></li>
        <li><Icon name="tool" class="bullet-icon" size={16} /><span>Diagnostico con propuesta de reparacion o reemplazo.</span></li>
        <li><Icon name="shield" class="bullet-icon" size={16} /><span>Ejecucion con plan de seguridad y continuidad operativa.</span></li>
        <li><Icon name="chart" class="bullet-icon" size={16} /><span>Entrega de informe tecnico con recomendaciones.</span></li>
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .card {
    padding: 1rem;
  }

  .card a {
    text-decoration: none;
    font-weight: 700;
    color: var(--brand);
  }

  .process {
    padding: 1rem;
  }
</style>
