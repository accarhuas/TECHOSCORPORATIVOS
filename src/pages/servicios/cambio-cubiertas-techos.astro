---
import ServicePage from "../../components/ServicePage.astro";

const title = "Cambio de cubiertas y techos | Techos Corporativos";
const description =
  "Servicio de cambio de cubiertas y techos para empresas en Chile. Reemplazo parcial o total con enfoque en continuidad operativa.";
---

<ServicePage
  title={title}
  description={description}
  h1="Cambio de cubiertas y techos para infraestructura empresarial"
  intro="Ejecutamos cambio de cubiertas deterioradas con planificacion por sectores para reducir riesgo de filtraciones y fallas recurrentes."
  bullets={[
    "Inspeccion tecnica de estructura y estado de cubierta",
    "Definicion de cambio parcial o total segun criticidad",
    "Retiro controlado de material deteriorado",
    "Instalacion de nueva cubierta con sellado de encuentros",
    "Informe tecnico de cierre con recomendaciones preventivas"
  ]}
  process={[
    "Levantamiento de metraje, accesos y restricciones operativas",
    "Propuesta tecnica y economica por etapas de ejecucion",
    "Ejecucion con protocolos de seguridad y control de calidad",
    "Entrega con validacion final de estanqueidad"
  ]}
/>
