---
import ServicePage from "../../components/ServicePage.astro";

const title = "Impermeabilizacion de techos | Techos Corporativos";
const description =
  "Impermeabilizacion de techos para empresas en Chile. Soluciones de sellado y proteccion para cubiertas metalicas e industriales.";
---

<ServicePage
  title={title}
  description={description}
  h1="Impermeabilizacion de techos para reducir filtraciones recurrentes"
  intro="Aplicamos soluciones de impermeabilizacion sobre cubiertas metalicas e industriales para mejorar estanqueidad y vida util."
  bullets={[
    "Evaluacion de estado de sellos y puntos vulnerables",
    "Preparacion de superficie y limpieza tecnica",
    "Aplicacion de sistema impermeabilizante segun cubierta",
    "Refuerzo en juntas, cumbreras y encuentros criticos",
    "Control final y recomendaciones de mantencion"
  ]}
  process={[
    "Diagnostico tecnico y definicion de sistema",
    "Intervencion por sectores para asegurar continuidad",
    "Aplicacion y curado con control de calidad",
    "Entrega de reporte y plan de revision preventiva"
  ]}
/>
