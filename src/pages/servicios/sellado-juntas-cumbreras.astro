---
import ServicePage from "../../components/ServicePage.astro";

const title = "Sellado de juntas y cumbreras | Techos Corporativos";
const description =
  "Sellado de juntas, traslapos y cumbreras en techumbres metalicas para reducir filtraciones en bodegas, industrias y sucursales.";
---

<ServicePage
  title={title}
  description={description}
  h1="Sellado de juntas y cumbreras en techumbres metalicas"
  intro="Refuerzo de estanqueidad en uniones criticas para eliminar ingreso de agua y mejorar desempeno de la cubierta."
  bullets={[
    "Diagnostico de juntas y uniones comprometidas",
    "Preparacion de superficie y retiro de sellos danados",
    "Aplicacion de sistema de sellado tecnico",
    "Refuerzo en cumbreras, traslapos y encuentros",
    "Control final de estanqueidad"
  ]}
  process={[
    "Levantamiento de sectores con filtracion activa",
    "Limpieza y acondicionamiento de puntos de union",
    "Sellado por tramos segun criticidad",
    "Validacion final y recomendaciones de mantencion"
  ]}
/>
