---
import ServicePage from "../../components/ServicePage.astro";

const title = "Inspeccion tecnica de techos | Techos Corporativos";
const description =
  "Inspeccion tecnica de techos para empresas en Chile. Diagnostico de riesgos, filtraciones y estado de cubierta con informe tecnico.";
---

<ServicePage
  title={title}
  description={description}
  h1="Inspeccion tecnica de techos con informe de riesgos"
  intro="Evaluamos estado real de techumbre para definir si conviene reparacion puntual, mantencion programada o cambio parcial de cubierta."
  bullets={[
    "Levantamiento de estado de cubierta y canaletas",
    "Mapa de filtraciones y puntos de falla",
    "Evaluacion de fijaciones y elementos criticos",
    "Estimacion preliminar de intervencion",
    "Informe tecnico con plan priorizado"
  ]}
  process={[
    "Inspeccion en terreno por sectores",
    "Registro fotografico y clasificacion de hallazgos",
    "Analisis de criticidad operacional",
    "Entrega de informe y propuesta tecnica"
  ]}
/>
