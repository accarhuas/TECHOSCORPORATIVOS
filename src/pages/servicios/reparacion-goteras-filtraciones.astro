---
import ServicePage from "../../components/ServicePage.astro";

const title = "Reparacion de goteras y filtraciones | Techos Corporativos";
const description =
  "Servicio B2B de reparacion de goteras y filtraciones en techumbres de empresas, bodegas y centros logisticos en Chile.";
---

<ServicePage
  title={title}
  description={description}
  h1="Reparacion de goteras y filtraciones en techumbres empresariales"
  intro="Detectamos la causa raiz del ingreso de agua y ejecutamos soluciones tecnicas para reducir recurrencia y dano estructural."
  bullets={[
    "Diagnostico de causa raiz de goteras y escurrimientos",
    "Sellado tecnico de puntos de ingreso",
    "Reparacion de juntas, traslapos y encuentros",
    "Correccion de pendientes y desagues comprometidos",
    "Plan preventivo para temporada de lluvias"
  ]}
  process={[
    "Inspeccion tecnica con trazado de filtraciones",
    "Pruebas de estanqueidad en zonas comprometidas",
    "Reparacion localizada o por panos segun criticidad",
    "Informe final con mejoras recomendadas"
  ]}
/>
