---
import ServicePage from "../../components/ServicePage.astro";

const title = "Reparacion de techos industriales | Techos Corporativos";
const description =
  "Reparacion de techos industriales para empresas en Chile. Correccion de filtraciones, uniones, fijaciones y puntos criticos.";
---

<ServicePage
  title={title}
  description={description}
  h1="Reparacion de techos industriales para continuidad operativa"
  intro="Intervenimos cubiertas metalicas e industriales con foco en filtraciones, fijaciones y sectores con desgaste avanzado."
  bullets={[
    "Inspeccion de cubierta y mapeo de puntos criticos",
    "Reparacion de uniones, traslapos, cumbreras y encuentros",
    "Cambio de fijaciones y refuerzo de anclajes",
    "Correccion de filtraciones activas y latentes",
    "Informe tecnico con recomendaciones preventivas"
  ]}
  process={[
    "Levantamiento tecnico en terreno por sectores",
    "Definicion de alcance por criticidad operativa",
    "Ejecucion por etapas para minimizar interrupciones",
    "Control de estanqueidad y cierre con evidencias"
  ]}
/>
