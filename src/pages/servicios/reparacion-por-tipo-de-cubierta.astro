---
import ServicePage from "../../components/ServicePage.astro";

const title = "Reparacion por tipo de cubierta | Techos Corporativos";
const description =
  "Reparacion de techos segun tipo de cubierta: metalica, policarbonato, teja asfaltica y sistemas mixtos para empresas en Chile.";
---

<ServicePage
  title={title}
  description={description}
  h1="Reparacion de techos segun tipo de cubierta"
  intro="Definimos la mejor solucion tecnica segun material y estado de la techumbre para mejorar estanqueidad y vida util."
  bullets={[
    "Reparacion de cubierta metalica industrial",
    "Reparacion de techos de policarbonato y encuentros",
    "Correccion en cubiertas con teja asfaltica",
    "Sellado tecnico en cubiertas mixtas y puntos de union",
    "Plan de mantencion recomendado por tipo de material"
  ]}
  process={[
    "Diagnostico del material y causa de la falla",
    "Seleccion de tecnica de reparacion compatible",
    "Intervencion focalizada por sector critico",
    "Pruebas de estanqueidad y cierre tecnico"
  ]}
/>
