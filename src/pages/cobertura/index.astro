---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
import { coveragePages } from "../../data/site";

const title = "Cobertura de reparacion de techos en Chile | Techos Corporativos";
const description =
  "Cobertura de reparacion de techos en Santiago y regiones de Chile. Coordinacion por zona, criticidad y continuidad operativa.";
---

<BaseLayout title={title} description={description}>
  <section class="hero-shell">
    <div class="wrap hero-box">
      <span class="kicker">Cobertura nacional</span>
      <h1>Reparacion de techos en Santiago y regiones</h1>
      <p>
        Coordinamos atencion tecnica segun criticidad y disponibilidad operativa. La cobertura se
        programa por tipo de instalacion, urgencia y distancia de ejecucion.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/contacto/">Consultar disponibilidad</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap grid-2">
      <article class="panel card">
        <h2 class="title-with-icon">
          <span class="icon-chip"><Icon name="map-pin" size={18} /></span>
          Comunas de cobertura prioritaria (RM)
        </h2>
        <p>
          Creamos una subpagina por comuna para que revises alcance tecnico, foco operativo y
          tiempos de atencion:
        </p>
        <ul class="communes">
          {
            coveragePages.map((commune) => (
              <li>
                <a href={`/reparacion-techos/${commune.slug}/`}>
                  <span class="commune-icon"><Icon name="map-pin" size={15} /></span>
                  <strong>{commune.name}</strong>
                  <small>{commune.responseWindow}</small>
                </a>
              </li>
            ))
          }
        </ul>
      </article>
      <article class="panel card">
        <h2 class="title-with-icon">
          <span class="icon-chip"><Icon name="building" size={18} /></span>
          Zonas de atencion complementaria
        </h2>
        <ul class="list-icon">
          <li><Icon name="map-pin" class="bullet-icon" size={16} /><span>Region Metropolitana (otras comunas por coordinacion)</span></li>
          <li><Icon name="map-pin" class="bullet-icon" size={16} /><span>Valparaiso y zona centro</span></li>
          <li><Icon name="map-pin" class="bullet-icon" size={16} /><span>Biobio y macrozona sur</span></li>
          <li><Icon name="map-pin" class="bullet-icon" size={16} /><span>Atencion en otras regiones por requerimiento</span></li>
        </ul>
      </article>
      <article class="panel card card-full">
        <h2 class="title-with-icon">
          <span class="icon-chip"><Icon name="checklist" size={18} /></span>
          Modelo de coordinacion
        </h2>
        <ul class="list-icon">
          <li><Icon name="tool" class="bullet-icon" size={16} /><span>Visita tecnica inicial y levantamiento</span></li>
          <li><Icon name="checklist" class="bullet-icon" size={16} /><span>Planificacion por sector y horario operativo</span></li>
          <li><Icon name="wrench" class="bullet-icon" size={16} /><span>Ejecucion por etapas</span></li>
          <li><Icon name="chart" class="bullet-icon" size={16} /><span>Reporte consolidado por sede o red</span></li>
        </ul>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .grid-2 {
    align-items: stretch;
  }

  .card {
    padding: 1rem;
  }

  .card-full {
    grid-column: 1 / -1;
  }

  .communes {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.5rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .communes li {
    padding: 0;
  }

  .communes a {
    display: flex;
    flex-direction: column;
    gap: 0.18rem;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: #f3f5f7;
    padding: 0.5rem 0.65rem;
    color: var(--ink);
    text-decoration: none;
  }

  .communes a strong {
    font-size: 1rem;
    margin-top: 0.1rem;
  }

  .communes a small {
    color: var(--ink-soft);
    font-size: 0.83rem;
  }

  .communes a:hover {
    border-color: #c5cdd7;
    background: #eceff3;
  }

  .commune-icon {
    color: var(--accent);
    line-height: 0;
  }

  @media (max-width: 640px) {
    .communes {
      grid-template-columns: 1fr;
    }
  }
</style>
