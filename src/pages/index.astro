---
import BaseLayout from "../layouts/BaseLayout.astro";
import { sectorCards, serviceLinks, siteConfig } from "../data/site";

const title = "Reparacion y cambio de techos | Techos Corporativos";
const description =
  "Reparacion y cambio de techos para empresas en Chile. Soluciones de goteras, filtraciones, impermeabilizacion y mantencion de techumbres industriales.";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: siteConfig.name,
  areaServed: "Chile",
  serviceType: [
    "Reparacion de techos",
    "Reparacion de goteras y filtraciones",
    "Impermeabilizacion de techos",
    "Cambio de techos industriales",
    "Mantencion anual de techumbres"
  ],
  url: `${siteConfig.siteUrl}/`,
  telephone: siteConfig.phoneDisplay
};
---

<BaseLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <section class="hero-shell">
    <div class="wrap hero-box">
      <span class="kicker">Especialistas B2B en Chile</span>
      <h1>Reparacion y cambio de techos para empresas en Chile</h1>
      <p>
        Ejecutamos reparacion de techos y cambio de techumbres en bodegas, centros logisticos,
        colegios y sucursales. Resolvemos filtraciones y goteras sin frenar tu operacion, con
        reporte tecnico y trazabilidad por sede.
      </p>
      <p class="hero-sub">
        Servicios clave: reparacion de techos industriales, impermeabilizacion y mantencion anual.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/contacto/">Solicitar evaluacion tecnica</a>
        <a class="btn btn-secondary" href="/planes-mantencion/">Ver plan anual</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <h2>Reparacion de techos, filtraciones y cambio de techumbres</h2>
      <p>
        Soluciones tecnicas para control de goteras, sellado de filtraciones y renovacion de
        cubiertas en infraestructura empresarial.
      </p>
      <div class="grid-2 cards">
        {
          serviceLinks.map((item) => (
            <article class="panel card">
              <h3>{item.title}</h3>
              <p>{item.summary}</p>
              <a href={item.href}>Ver detalle del servicio</a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <h2>Por que empresas nos eligen</h2>
      <div class="panel metrics">
        <article>
          <h3>{siteConfig.yearsExperience}</h3>
          <p>Anos de experiencia en techumbres empresariales.</p>
        </article>
        <article>
          <h3>24 a 72h</h3>
          <p>Ventana de respuesta para evaluacion inicial segun zona.</p>
        </article>
        <article>
          <h3>1 estandar</h3>
          <p>Metodologia unica para casa matriz y sucursales.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <h2>Programas de mantencion anual para continuidad operativa</h2>
      <p>
        Disenamos planes preventivos para reducir urgencias, controlar costos y extender vida
        util de techumbres. Puedes contratar por sede o para toda la red de sucursales.
      </p>
      <div class="grid-3 cards">
        <article class="panel card">
          <h3>Plan Preventivo</h3>
          <p>2 visitas al ano con foco en temporada de lluvia y cierre tecnico.</p>
        </article>
        <article class="panel card">
          <h3>Plan Operacional</h3>
          <p>4 visitas al ano para instalaciones con uso continuo.</p>
        </article>
        <article class="panel card">
          <h3>Plan Critico</h3>
          <p>6 a 12 visitas en infraestructura sensible o de alta exigencia.</p>
        </article>
      </div>
      <a class="btn btn-primary" href="/planes-mantencion/">Solicitar plan anual</a>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <h2>Proceso de trabajo para reparacion y cambio de techos</h2>
      <div class="grid-3 cards">
        <article class="panel card">
          <h3>1. Inspeccion tecnica</h3>
          <p>Levantamiento de cubierta, riesgos y puntos de filtracion por sector.</p>
        </article>
        <article class="panel card">
          <h3>2. Propuesta y plan</h3>
          <p>Definimos alcance: reparacion de techos, impermeabilizacion o cambio de techumbre.</p>
        </article>
        <article class="panel card">
          <h3>3. Ejecucion y cierre</h3>
          <p>Intervencion por etapas, control de calidad y entrega de informe tecnico final.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <h2>Industrias y organizaciones que atendemos</h2>
      <div class="grid-3 cards">
        {
          sectorCards.map((sector) => (
            <article class="panel card">
              <h3>{sector}</h3>
              <p>Mantencion y reparaciones programadas segun criticidad operacional.</p>
            </article>
          ))
        }
      </div>
      <a href="/sectores/">Ver cobertura por tipo de institucion</a>
    </div>
  </section>

  <section class="section">
    <div class="wrap grid-2">
      <article class="panel card">
        <h2>Cobertura nacional</h2>
        <p>
          Operamos en Santiago y regiones segun requerimiento. Coordinamos visitas tecnicas por
          prioridad, criticidad y ventana operativa del cliente.
        </p>
        <a href="/cobertura/">Revisar cobertura</a>
      </article>
      <article class="panel card">
        <h2>Contacto tecnico</h2>
        <p>
          Cuentanos tipo de inmueble, ubicacion y urgencia. Te devolvemos diagnostico y alcance
          preliminar de trabajo.
        </p>
        <a class="btn btn-secondary" href="/contacto/">Ir a contacto</a>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <h2>Preguntas frecuentes</h2>
      <div class="grid-3 cards">
        <article class="panel card">
          <h3>Conviene reparar o cambiar la techumbre?</h3>
          <p>
            Depende del dano y vida util restante. Evaluamos en terreno si conviene reparacion de
            techos o cambio parcial/total.
          </p>
        </article>
        <article class="panel card">
          <h3>Pueden trabajar sin detener la operacion?</h3>
          <p>
            Si. Planificamos por sectores y horarios para minimizar impacto en bodegas y
            sucursales activas.
          </p>
        </article>
        <article class="panel card">
          <h3>Incluyen reportes tecnicos?</h3>
          <p>
            Si. Cada servicio incluye informe de hallazgos, intervencion ejecutada y
            recomendaciones de mantencion.
          </p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-sub {
    margin-top: -0.35rem;
    margin-bottom: 0.9rem;
    color: #d8e8f2;
  }

  .card a {
    color: var(--brand);
    font-weight: 700;
    text-decoration: none;
  }

  .card a:hover {
    text-decoration: underline;
  }

  .metrics {
    padding: 1rem;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .metrics article {
    border-radius: 14px;
    border: 1px solid var(--line);
    background: linear-gradient(170deg, #f7fbfd, #ffffff);
    padding: 0.8rem;
    text-align: center;
  }

  .metrics h3 {
    color: var(--brand-2);
  }

  @media (max-width: 900px) {
    .metrics {
      grid-template-columns: 1fr;
    }
  }
</style>
