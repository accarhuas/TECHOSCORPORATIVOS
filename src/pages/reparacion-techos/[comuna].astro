---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
import { coveragePages, serviceLinks, siteConfig } from "../../data/site";

export function getStaticPaths() {
  return coveragePages.map((page) => ({
    params: { comuna: page.slug },
    props: { page }
  }));
}

const { page } = Astro.props;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: page.faq.map((item: { question: string; answer: string }) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer
    }
  }))
};

const localUrl = `${siteConfig.siteUrl}/reparacion-techos/${page.slug}/`;

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: `Reparacion de techos en ${page.name}`,
  areaServed: {
    "@type": "City",
    name: page.name,
    containedIn: {
      "@type": "AdministrativeArea",
      name: "Region Metropolitana"
    }
  },
  provider: {
    "@type": "Organization",
    name: siteConfig.name
  },
  serviceType: [
    "Reparacion de techos",
    "Reparacion de goteras y filtraciones",
    "Impermeabilizacion de techumbres",
    "Cambio de techos industriales"
  ],
  url: localUrl
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Inicio", item: `${siteConfig.siteUrl}/` },
    {
      "@type": "ListItem",
      position: 2,
      name: "Cobertura",
      item: `${siteConfig.siteUrl}/cobertura/`
    },
    {
      "@type": "ListItem",
      position: 3,
      name: page.name,
      item: localUrl
    }
  ]
};

const nearby = coveragePages.filter((item) => item.slug !== page.slug).slice(0, 4);
---

<BaseLayout title={page.title} description={page.description}>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <section class="hero-shell">
    <div class="wrap hero-box">
      <span class="kicker">Cobertura local</span>
      <h1>Reparacion de techos en {page.name}</h1>
      <p>{page.intro}</p>
      <p class="response"><strong>Tiempo de respuesta estimado:</strong> {page.responseWindow}.</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/contacto/">Solicitar visita en {page.name}</a>
        <a class="btn btn-secondary" href="/cobertura/">Volver a cobertura</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap grid-2">
      <article class="panel card">
        <h2 class="title-with-icon">
          <span class="icon-chip"><Icon name="building" size={18} /></span>
          Tipo de operaciones que atendemos en {page.name}
        </h2>
        <ul class="list-icon">
          {
            page.localFocus.map((item: string) => (
              <li>
                <Icon name="shield" class="bullet-icon" size={16} />
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </article>
      <article class="panel card">
        <h2 class="title-with-icon">
          <span class="icon-chip"><Icon name="tool" size={18} /></span>
          Problemas de cubierta mas frecuentes
        </h2>
        <ul class="list-icon">
          {
            page.commonIssues.map((item: string) => (
              <li>
                <Icon name="wrench" class="bullet-icon" size={16} />
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <h2>Servicios recomendados para {page.name}</h2>
      <div class="grid-2 cards">
        {serviceLinks.map((service) => (
          <article class="panel card">
            <span class="icon-chip icon-chip-accent"><Icon name="checklist" size={18} /></span>
            <h3>{service.title}</h3>
            <p>{service.summary}</p>
            <a href={service.href}>Ver servicio</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap grid-2">
      <article class="panel card">
        <h2 class="title-with-icon">
          <span class="icon-chip"><Icon name="chat" size={18} /></span>
          Preguntas frecuentes en {page.name}
        </h2>
        {page.faq.map((item: { question: string; answer: string }) => (
          <div class="faq-item">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </div>
        ))}
      </article>
      <article class="panel card">
        <h2 class="title-with-icon">
          <span class="icon-chip"><Icon name="map-pin" size={18} /></span>
          Otras comunas de cobertura cercana
        </h2>
        <ul class="list-icon">
          {
            nearby.map((item) => (
              <li>
                <Icon name="map-pin" class="bullet-icon" size={16} />
                <a href={`/reparacion-techos/${item.slug}/`}>{item.name}</a>
              </li>
            ))
          }
        </ul>
        <div class="hero-actions">
          <a class="btn btn-primary" href="/contacto/">Hablar con un asesor tecnico</a>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .card {
    padding: 1rem;
  }

  .response {
    margin: 0.2rem 0 0.95rem;
    color: #e5e9ee;
  }

  .faq-item + .faq-item {
    margin-top: 0.9rem;
    padding-top: 0.9rem;
    border-top: 1px solid var(--line);
  }

  .card a {
    text-decoration: none;
    color: var(--brand);
    font-weight: 700;
  }

  .card a:hover {
    text-decoration: underline;
  }
</style>
