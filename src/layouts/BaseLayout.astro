---
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";
import { siteConfig } from "../data/site";

interface Props {
  title: string;
  description: string;
  noindex?: boolean;
}

const { title, description, noindex = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL("/icon-512.png", Astro.site).toString();
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: siteConfig.name,
  legalName: siteConfig.legalName,
  url: siteConfig.siteUrl,
  areaServed: siteConfig.serviceArea,
  email: siteConfig.email,
  telephone: siteConfig.phoneDisplay
};
---

<!doctype html>
<html lang="es-CL">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="application-name" content={siteConfig.name} />
    <meta name="apple-mobile-web-app-title" content={siteConfig.name} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="robots" content={noindex ? "noindex,nofollow" : "index,follow,max-image-preview:large"} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_CL" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="Techos Corporativos - Reparacion y cambio de techos" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="theme-color" content="#1e242c" />
    <meta name="format-detection" content="telephone=no" />
    <link rel="alternate" hrefLang="es-CL" href={canonical} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;700&family=Source+Sans+3:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <a class="skip-link" href="#contenido">Saltar al contenido</a>
    <Navbar />
    <main id="contenido">
      <slot />
    </main>
    <Footer />
    <a
      class="whatsapp-float"
      href={siteConfig.whatsapp}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Abrir WhatsApp para cotizacion"
    >
      <span class="whatsapp-chat-bubble" aria-hidden="true">
        ¿Cotizamos?
      </span>
      <span class="whatsapp-icon-wrap" aria-hidden="true">
        <svg viewBox="0 0 24 24" role="img" focusable="false">
          <path
            fill="currentColor"
            d="M20.52 3.48A11.86 11.86 0 0 0 12.05 0C5.45 0 .08 5.38.08 11.98c0 2.1.55 4.16 1.59 5.98L0 24l6.2-1.62a11.96 11.96 0 0 0 5.76 1.47h.01c6.6 0 11.98-5.38 11.98-11.98 0-3.2-1.25-6.2-3.43-8.39zm-8.55 18.34h-.01a9.9 9.9 0 0 1-5.04-1.38l-.36-.21-3.68.97.98-3.58-.24-.37a9.9 9.9 0 0 1-1.53-5.27C2.09 6.5 6.57 2.03 12.06 2.03c2.65 0 5.13 1.04 7.01 2.91a9.86 9.86 0 0 1 2.9 7.03c0 5.48-4.46 9.95-9.94 9.95zm5.46-7.43c-.3-.15-1.76-.87-2.04-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.95 1.17-.17.2-.35.22-.64.07-.3-.15-1.24-.46-2.35-1.47-.87-.78-1.45-1.74-1.62-2.04-.17-.3-.02-.45.13-.6.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.62-.92-2.22-.24-.57-.49-.5-.67-.51h-.57c-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.5s1.06 2.9 1.21 3.1c.15.2 2.07 3.16 5.01 4.43.7.3 1.24.48 1.67.62.7.22 1.33.19 1.83.12.56-.08 1.76-.72 2.01-1.42.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35z"
          ></path>
        </svg>
        <span class="whatsapp-badge">1</span>
      </span>
    </a>
  </body>
</html>

<style is:global>
  :root {
    --bg: #f3f5f7;
    --surface: #ffffff;
    --ink: #111317;
    --ink-soft: #4b5563;
    --brand: #46515f;
    --brand-2: #1e242c;
    --accent: #ffd200;
    --line: #d6dde5;
    --radius: 18px;
    --shadow: 0 22px 48px rgba(17, 19, 23, 0.12);
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    background:
      radial-gradient(1200px 400px at 100% -20%, rgba(70, 81, 95, 0.18), transparent 70%),
      radial-gradient(900px 300px at -10% -20%, rgba(255, 210, 0, 0.16), transparent 70%),
      var(--bg);
    color: var(--ink);
    font-family: "Source Sans 3", sans-serif;
    line-height: 1.45;
  }

  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
  }

  .skip-link:focus {
    left: 10px;
    top: 10px;
    z-index: 50;
    padding: 0.5rem 0.8rem;
    border-radius: 8px;
    background: #fff;
    border: 1px solid var(--line);
  }

  .whatsapp-float {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 35;
    width: 64px;
    height: 64px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.72);
    background: radial-gradient(circle at 30% 24%, #45dd7d, #19b85a 68%);
    color: #fff;
    text-decoration: none;
    box-shadow: 0 16px 30px rgba(17, 19, 23, 0.28);
    transition: transform 180ms ease, filter 180ms ease;
    isolation: isolate;
    animation: whatsapp-float 2.5s ease-in-out infinite;
  }

  .whatsapp-float:hover {
    transform: translateY(-2px);
    filter: brightness(1.04);
  }

  .whatsapp-float:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }

  .whatsapp-float::before,
  .whatsapp-float::after {
    content: "";
    position: absolute;
    inset: -8px;
    border-radius: inherit;
    border: 2px solid rgba(32, 200, 99, 0.48);
    z-index: -1;
    opacity: 0;
    pointer-events: none;
    animation: whatsapp-wave 2.8s ease-out infinite;
  }

  .whatsapp-float::after {
    animation-delay: 1.4s;
  }

  .whatsapp-icon-wrap {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    display: grid;
    place-items: center;
    position: relative;
  }

  .whatsapp-icon-wrap svg {
    width: 33px;
    height: 33px;
    color: #fff;
  }

  .whatsapp-badge {
    position: absolute;
    right: -4px;
    top: -3px;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: #ff5c66;
    color: #fff;
    font-weight: 700;
    font-size: 0.92rem;
    border: 2px solid #fff;
    box-shadow: 0 8px 18px rgba(17, 19, 23, 0.28);
  }

  .whatsapp-chat-bubble {
    position: absolute;
    right: 0;
    bottom: calc(100% + 14px);
    background: #fff;
    color: #2f3d47;
    border-radius: 14px;
    padding: 0.66rem 0.88rem;
    font-size: 1.04rem;
    line-height: 1.1;
    font-weight: 600;
    box-shadow: 0 10px 20px rgba(17, 19, 23, 0.18);
    white-space: nowrap;
    border: 1px solid rgba(17, 19, 23, 0.08);
    transform-origin: 88% 100%;
    animation: chat-bubble-idle 4.2s ease-in-out infinite;
  }

  .whatsapp-chat-bubble::after {
    content: "";
    position: absolute;
    right: 18px;
    top: calc(100% - 5px);
    width: 12px;
    height: 12px;
    background: #fff;
    border-right: 1px solid rgba(17, 19, 23, 0.08);
    border-bottom: 1px solid rgba(17, 19, 23, 0.08);
    transform: rotate(45deg);
  }

  .whatsapp-float:hover .whatsapp-chat-bubble {
    animation-play-state: paused;
    transform: scale(1.02);
  }

  :global(body.nav-locked) .whatsapp-float {
    pointer-events: none;
    filter: blur(2px);
  }

  @keyframes whatsapp-wave {
    0% {
      transform: scale(0.82);
      opacity: 0.55;
    }

    70% {
      opacity: 0.18;
    }

    100% {
      transform: scale(1.28);
      opacity: 0;
    }
  }

  @keyframes whatsapp-float {
    0%,
    100% {
      transform: translateY(0);
    }

    50% {
      transform: translateY(-2px);
    }
  }

  @keyframes chat-bubble-idle {
    0%,
    84%,
    100% {
      transform: scale(1);
    }

    89% {
      transform: scale(1.03);
    }
  }

  h1,
  h2,
  h3 {
    margin: 0 0 0.7rem;
    font-family: "Barlow Condensed", sans-serif;
    letter-spacing: 0.01em;
    line-height: 1.05;
  }

  h1 {
    font-size: clamp(2rem, 6vw, 3.6rem);
  }

  h2 {
    font-size: clamp(1.7rem, 3vw, 2.35rem);
  }

  h3 {
    font-size: clamp(1.2rem, 2.2vw, 1.5rem);
  }

  p {
    margin: 0 0 1rem;
    color: var(--ink-soft);
    font-size: 1.06rem;
  }

  .wrap {
    width: min(1240px, 92vw);
    margin: 0 auto;
  }

  .section {
    padding: clamp(2.6rem, 4vw, 4.6rem) 0;
  }

  .panel {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  .title-with-icon {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }

  .icon-chip {
    width: 34px;
    height: 34px;
    border-radius: 10px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--brand-2);
    background: #eef1f5;
    border: 1px solid var(--line);
    flex: 0 0 auto;
  }

  .icon-chip.icon-chip-accent {
    color: var(--brand-2);
    background: rgba(255, 210, 0, 0.32);
    border-color: rgba(255, 210, 0, 0.45);
  }

  .list-icon {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }

  .list-icon li {
    display: grid;
    grid-template-columns: 22px 1fr;
    gap: 0.45rem;
    align-items: start;
    color: var(--ink-soft);
  }

  .list-icon .bullet-icon {
    margin-top: 0.1rem;
    color: var(--accent);
  }

  .kicker {
    display: inline-block;
    padding: 0.25rem 0.7rem;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--brand-2);
    background: var(--accent);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 0.75rem 1.15rem;
    border-radius: 10px;
    border: 0;
    text-decoration: none;
    font-weight: 700;
    transition: transform 180ms ease, filter 180ms ease;
    cursor: pointer;
  }

  .btn:hover {
    transform: translateY(-2px);
    filter: brightness(1.04);
  }

  .btn-primary {
    background: var(--accent);
    color: var(--ink);
  }

  .btn-secondary {
    background: var(--surface);
    border: 1px solid var(--brand-2);
    color: var(--brand-2);
  }

  .grid-2,
  .grid-3 {
    display: grid;
    gap: 1rem;
  }

  .grid-2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .grid-3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .hero-shell {
    padding: clamp(1.2rem, 4vw, 3rem) 0 clamp(2rem, 5vw, 4rem);
  }

  .hero-box {
    border-radius: var(--radius);
    padding: clamp(1.1rem, 3vw, 2rem);
    color: #fff;
    background: linear-gradient(162deg, #171b21 5%, var(--brand-2) 55%, var(--brand) 100%);
    box-shadow: var(--shadow);
    overflow: hidden;
    position: relative;
  }

  .hero-box::after {
    content: "";
    position: absolute;
    width: 420px;
    height: 420px;
    right: -170px;
    top: -230px;
    border-radius: 50%;
    background: rgba(255, 210, 0, 0.34);
  }

  .hero-box p {
    color: #e5e9ee;
    max-width: 72ch;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .cards .card {
    padding: 1rem;
  }

  ul.clean {
    margin: 0;
    padding-left: 1rem;
    color: var(--ink-soft);
  }

  @media (max-width: 900px) {
    .grid-2,
    .grid-3 {
      grid-template-columns: 1fr;
    }

    .wrap {
      width: min(1240px, 94vw);
    }

    .whatsapp-float {
      right: 0.75rem;
      bottom: 0.75rem;
      width: 58px;
      height: 58px;
    }

    .whatsapp-chat-bubble,
    .whatsapp-badge {
      display: none;
    }

    .whatsapp-icon-wrap svg {
      width: 30px;
      height: 30px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .whatsapp-float,
    .whatsapp-float::before,
    .whatsapp-float::after {
      animation: none;
    }
  }
</style>

